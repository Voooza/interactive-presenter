# ===========================================================================
# Interactive Presenter — Production Configuration
#
# Copy this file to .env and fill in the values before deploying.
# ===========================================================================

# The public domain name for your instance (e.g. slides.example.com).
# DNS must point to your VPS before running deploy.sh.
DOMAIN=slides.example.com

# Email address for Let's Encrypt certificate notifications
# (expiry warnings, policy changes).
CERTBOT_EMAIL=admin@example.com
