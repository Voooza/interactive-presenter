# ===========================================================================
# Interactive Presenter — Environment Configuration (optional)
#
# Copy to .env if you need to override defaults.
# Currently there are no required variables — the app runs with sensible
# defaults from docker-compose.yml.
# ===========================================================================

# Directory inside the container where presentations are read from.
# The docker-compose volume mount maps ./presentations → this path.
# PRESENTATIONS_DIR=/app/presentations

# Directory inside the container for the pre-built frontend assets.
# STATIC_DIR=/app/frontend/dist
